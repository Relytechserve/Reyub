# Copy to .env.local and fill in values.

# Neon Postgres — https://neon.tech
DATABASE_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (production: https://your-domain.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# Qogita Buyer API — https://qogita.notion.site/Qogita-Buyer-API-Beta-556b22869bcb47d2bffac8d2a8c7076a
# Server-only (no NEXT_PUBLIC_*). Add the same keys in Vercel → Project → Settings → Environment Variables.
#
# Option A — you already have a bearer/API token (or it is long-lived):
#   QOGITA_API_TOKEN=...
#
# Option B — token is obtained by logging in with email/password (we will implement exchange in code):
#   QOGITA_EMAIL=...
#   QOGITA_PASSWORD=...
#   (Or a refresh token if their API documents one — prefer that over raw password when available.)
#
# Login (recommended): access token is obtained at runtime via POST /auth/login/ — do not commit secrets.
QOGITA_EMAIL=
QOGITA_PASSWORD=
# Optional override: pin a bearer token instead of logging in (advanced).
QOGITA_API_TOKEN=

# Keepa API (Amazon UK matching — https://keepa.com/#!api )
KEEPA_API_KEY=

# Amazon browse node IDs (comma-separated) for Keepa bestseller discovery — same IDs as Amazon category URLs.
# Domain 2 = Amazon UK. Examples:
#   118457031 — Beauty › Fragrances (UK)
#   266239 — Books
# Verify with Keepa category API or Amazon category URLs.
KEEPA_BESTSELLER_CATEGORY_IDS=118457031
# Optional overrides (defaults match UK bestseller pull):
KEEPA_DOMAIN=2
KEEPA_BESTSELLERS_PER_CATEGORY=100
KEEPA_BESTSELLER_RANGE=30
# Expand each ID in KEEPA_BESTSELLER_CATEGORY_IDS to direct child browse nodes (Keepa category API), then pull bestsellers per child — needed to exceed ~100 ASINs from a single parent node.
# KEEPA_BESTSELLER_EXPAND_CHILDREN=1
# Cap bestseller API calls per sync (safety). Raise with EXPAND_CHILDREN for wide trees (~25–40 for ~2000 ASINs).
KEEPA_BESTSELLER_MAX_CATEGORIES=30
# Stop fetching more categories once this many unique ASINs are collected from bestseller lists (before product lookup).
KEEPA_BESTSELLER_TARGET_ASINS=2000
# Include ~30d Keepa price/rank time series (`csv`, `salesRanks`, …) in DB metrics — uses more API tokens.
KEEPA_PRODUCT_INCLUDE_HISTORY=1
KEEPA_HISTORY_DAYS=30

# Max Qogita offers to pull per sync (pagination). Increase with large Keepa catalogs so EAN matches are possible.
QOGITA_SYNC_MAX_OFFERS=2000

# Optional: override offers URL (default /offers/). Filter to a category when the API supports it (confirm slug in Qogita docs), e.g. fragrance:
# QOGITA_OFFERS_PATH=/offers/?category=fragrance
QOGITA_OFFERS_PATH=

# eBay (Browse API / OAuth app credentials — platform-held)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Resend — https://resend.com (alerts & transactional email)
RESEND_API_KEY=

# Optional: protect /api/cron/sync when called outside Vercel Cron
CRON_SECRET=
